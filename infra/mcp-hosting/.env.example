# MCP hosting 환경변수 (예시).
# 실제 파일은 인스턴스 /etc/mcp-hosting/env 에 위치하며 git 미관리. 권한 0600 mcp:mcp.
# 설계: docs/architecture/v1/cross-cutting/mcp-hosting.md §8.2
#
# 토큰 생성:  openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# DB 패스워드: 별도 32B random. Supabase 대시보드/SQL 에서 role 에 설정.

# ── 엔드포인트별 Bearer (auth-proxy 검증) ──────────────────────────
# 엔드포인트명(첫 path 세그먼트) → 대문자 + '-'→'_'. /supabase-real → SUPABASE_REAL
MCP_TOKEN_SUPABASE_DEV=replace-with-base64url-32B
MCP_TOKEN_SUPABASE_REAL=replace-with-base64url-32B
MCP_TOKEN_PLAYWRIGHT=replace-with-base64url-32B
MCP_TOKEN_SENTRY=replace-with-base64url-32B
# MCP_TOKEN_GITHUB=replace-with-base64url-32B   # github-mcp 옵트인 시

# rotation grace: 신토큰 발급 시 _NEXT 추가 → auth-proxy 가 현재+NEXT 둘 다 허용 (§8.3)
# MCP_TOKEN_SUPABASE_REAL_NEXT=

# ── DB 접속 (Supavisor 세션 풀러, IPv4, 포트 5432) ─────────────────
# 사용자명은 <role>.<project_ref> 형식. role 은 sql/ 로 생성한 제한 role.
DATABASE_URI_DEV=postgresql://mcp_ro_dev.eqoywqoalwkwbrdsulfl:PW@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URI_REAL=postgresql://mcp_ro_real.lfrnythcujxdhehvkmtg:PW@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# ── Sentry (read scope) ───────────────────────────────────────────
SENTRY_AUTH_TOKEN=
SENTRY_HOST=sentry.io

# ── GitHub (옵션, fine-grained PAT read scope) ────────────────────
# GITHUB_PERSONAL_ACCESS_TOKEN=

# ── auth-proxy 옵션 ───────────────────────────────────────────────
# MCP_LOG_LEVEL=info
