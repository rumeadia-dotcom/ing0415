# Market Gateway 환경변수 (예시).
# 실제 파일은 /etc/market-gateway/env 에 위치하며 git 미관리. 권한 0640 root:marketgw.
# Supabase Edge Function env 측 MARKET_GATEWAY_SECRET 과 동일 값 유지.

# 32 bytes hex.  openssl rand -hex 32
MARKET_GATEWAY_SECRET=replace-with-openssl-rand-hex-32

# 게이트웨이 listen 포트. Caddy 가 127.0.0.1:8787 로 reverse-proxy.
MARKET_GATEWAY_PORT=8787

# debug | info | warn | error
MARKET_GATEWAY_LOG_LEVEL=info

# 옵션: Sentry 연동 시
# SENTRY_DSN=
